{
  "name": "cheshirecode-vite-react-unocss-boilerplate",
  "description": "Boilerplate for Vite 8 + React + UnoCSS, with linting",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "typecheck": "tsgo --noEmit",
    "preview": "vite preview",
    "format": "prettier --write {**/*,*}.{js,ts,jsx,tsx}",
    "lint": "eslint",
    "test": "vitest run"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260617.2",
    "@unocss/reset": "^66.7.2",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "unocss": "^66.7.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
